# PureScan Foods - Environment Variables
# Copy this file to .env and fill the missing values from the relevant panels.

# --- Firebase (already configured) ---
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=
# EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- RevenueCat ---
# Android public key (already set). iOS public key obtained from RevenueCat dashboard
# (App > iOS app > API Keys > Public app-specific key, starts with `appl_`).
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=goog_HuNdEyovEaZwmqMsypStOzQjhJo
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=

# --- Google Mobile Ads (AdMob) ---
# iOS production values obtained after registering the app in AdMob.
# Until populated, debug builds use Google's test IDs automatically.
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_ID=
EXPO_PUBLIC_ADMOB_IOS_REWARDED_ID=
# Android production values (already wired via app.config.ts default)
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-5745551393591703~9022078771

# --- Google Sign-In ---
# iOS reversed client ID is derived from GoogleService-Info.plist
# (REVERSED_CLIENT_ID). Override only if you have multiple Firebase projects.
# EXPO_PUBLIC_GOOGLE_IOS_REVERSED_CLIENT_ID=

# --- Gemini (handled server-side via Firebase Callable) ---
# Do NOT set EXPO_PUBLIC_GEMINI_API_KEY here. The key must remain server-side
# (Firebase Functions). Anything prefixed EXPO_PUBLIC_ ends up in the JS bundle.
